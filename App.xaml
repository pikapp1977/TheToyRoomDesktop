<Application x:Class="TheToyRoomDesktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Purple Theme Colors -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#6f42c1"/>
            <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#5a32a3"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="#e9ecef"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="#f8f9fa"/>
            <SolidColorBrush x:Key="TextBrush" Color="#212529"/>
            
            <!-- Button Style -->
            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
