<Window x:Class="TheToyRoomDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Toy Room" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Top Menu Bar -->
        <Menu Grid.Row="0" Background="#6f42c1" Foreground="White">
            <MenuItem Header="Home" Click="Home_Click" Foreground="White"/>
            <MenuItem Header="My Collection" Click="Collection_Click" Foreground="White"/>
            <MenuItem Header="Add Item" Click="AddItem_Click" Foreground="White"/>
            <MenuItem Header="Reports" Click="Reports_Click" Foreground="White"/>
            <MenuItem Header="Importer" Click="Importer_Click" Foreground="White"/>
            <MenuItem Header="Settings" Click="Settings_Click" Foreground="White"/>
        </Menu>
        
        <!-- Content Area -->
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
