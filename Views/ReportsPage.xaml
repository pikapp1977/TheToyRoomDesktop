<Page x:Class="TheToyRoomDesktop.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reports"
      Background="#f8f9fa">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Reports" FontSize="32" FontWeight="Bold" Foreground="#6f42c1" Margin="0,0,0,20"/>
        
        <!-- Filter Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Filter by Manufacturer:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <ComboBox x:Name="ManufacturerFilter" Grid.Column="1" Padding="8" SelectionChanged="ManufacturerFilter_SelectionChanged"/>
            <Button Grid.Column="2" Content="Clear Filter" Click="ClearFilter_Click" Margin="10,0,0,0" Padding="15,8"/>
            <Button Grid.Column="3" Content="Export to Excel" Click="ExportExcel_Click" Margin="10,0,0,0" Padding="15,8" Background="#28a745"/>
        </Grid>
        
        <!-- Data Grid -->
        <DataGrid x:Name="ReportsGrid" 
                  Grid.Row="2"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#dee2e6"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowBackground="White"
                  AlternatingRowBackground="#f8f9fa"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Character" Binding="{Binding Character}" Width="*"/>
                <DataGridTextColumn Header="Deco" Binding="{Binding DecoName}" Width="100"/>
                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="*"/>
                <DataGridTextColumn Header="Original" Binding="{Binding OriginalPrice, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Current" Binding="{Binding CurrentValue, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Gain/Loss" Binding="{Binding GainLoss, StringFormat=C2}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Summary -->
        <Border Grid.Row="3" Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Total Items:" FontWeight="Bold"/>
                    <TextBlock x:Name="TotalItemsText" Text="0" FontSize="20" Foreground="#6f42c1"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Total Original:" FontWeight="Bold"/>
                    <TextBlock x:Name="TotalOriginalText" Text="$0.00" FontSize="20" Foreground="#28a745"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Total Current:" FontWeight="Bold"/>
                    <TextBlock x:Name="TotalCurrentText" Text="$0.00" FontSize="20" Foreground="#007bff"/>
                </StackPanel>
                
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Total Gain/Loss:" FontWeight="Bold"/>
                    <TextBlock x:Name="TotalGainLossText" Text="$0.00" FontSize="20"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
