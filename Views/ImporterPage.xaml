<Page x:Class="TheToyRoomDesktop.Views.ImporterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Collection Importer"
      Background="#f8f9fa">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="800">
            <TextBlock Text="Collection Importer" FontSize="32" FontWeight="Bold" Foreground="#6f42c1" Margin="0,0,0,20"/>
            
            <!-- Instructions -->
            <Border Background="#e7f3ff" BorderBrush="#b8daff" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="How to Import:" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                        1. Download the import template below
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                        2. Fill in your collection data (Name and Manufacturer are required)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                        3. Upload the completed file
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap">
                        4. Review and select items to import
                    </TextBlock>
                </StackPanel>
            </Border>
            
            <!-- Template Download -->
            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Step 1: Download Template" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Content="Download Import Template" Click="DownloadTemplate_Click" Padding="20,10" HorizontalAlignment="Left" Background="#28a745"/>
                </StackPanel>
            </Border>
            
            <!-- File Upload -->
            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Step 2: Upload Completed File" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FilePathBox" Grid.Column="0" Padding="8" IsReadOnly="True" Background="#e9ecef"/>
                        <Button Grid.Column="1" Content="Choose File" Click="ChooseFile_Click" Margin="10,0,0,0" Padding="15,8"/>
                    </Grid>
                    <Button x:Name="ParseButton" Content="Parse File" Click="ParseFile_Click" Margin="0,10,0,0" Padding="20,10" HorizontalAlignment="Left" IsEnabled="False"/>
                </StackPanel>
            </Border>
            
            <!-- Preview Results -->
            <Border x:Name="PreviewBorder" Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Step 3: Review and Import" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <!-- Summary -->
                    <StackPanel x:Name="SummaryPanel" Margin="0,0,0,15">
                        <TextBlock x:Name="SummaryText" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock x:Name="SkippedText" TextWrapping="Wrap" Foreground="#dc3545" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <!-- Selection Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Select All" Click="SelectAll_Click" Padding="15,8" Margin="0,0,10,0"/>
                        <Button Content="Deselect All" Click="DeselectAll_Click" Padding="15,8"/>
                    </StackPanel>
                    
                    <!-- Preview Grid -->
                    <DataGrid x:Name="PreviewGrid" 
                              AutoGenerateColumns="False"
                              MaxHeight="400"
                              Background="White"
                              BorderBrush="#dee2e6"
                              BorderThickness="1"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowBackground="White"
                              AlternatingRowBackground="#f8f9fa"
                              CanUserResizeRows="False"
                              CanUserReorderColumns="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Import" Binding="{Binding IsSelected}" Width="60"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Character" Binding="{Binding Character}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Original" Binding="{Binding OriginalPrice, StringFormat=C2}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Current" Binding="{Binding CurrentValue, StringFormat=C2}" Width="100" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Import Button -->
                    <Button Content="Import Selected Items" Click="ImportItems_Click" Margin="0,15,0,0" Padding="30,10" HorizontalAlignment="Center" Background="#28a745"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
