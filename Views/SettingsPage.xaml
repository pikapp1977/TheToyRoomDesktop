<Page x:Class="TheToyRoomDesktop.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="#f8f9fa">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="800">
            <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" Foreground="#6f42c1" Margin="0,0,0,20"/>
            
            <!-- Database Info -->
            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Database Information" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Database Path:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DbPathText" TextWrapping="Wrap" Margin="0,5"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="File Size:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DbSizeText" Margin="0,5"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Items:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TotalItemsText" Margin="0,5"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Manufacturers:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ManufacturersText" Margin="0,5"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Decos:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DecosText" Margin="0,5"/>
                    </Grid>
                    
                    <Button Content="Refresh" Click="Refresh_Click" Margin="0,15,0,0" Padding="15,8" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <!-- Manage Manufacturers -->
            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Manage Manufacturers" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ Add New" Click="AddManufacturer_Click" Padding="15,8" Background="#28a745" Foreground="White"/>
                    </Grid>
                    
                    <DataGrid x:Name="ManufacturersGrid" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Height="200"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Date Added" Binding="{Binding DateAdded, StringFormat='{}{0:MM/dd/yyyy}'}" Width="120"/>
                            <DataGridTemplateColumn Header="Actions" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Delete" Click="DeleteManufacturer_Click" Tag="{Binding Id}" Padding="10,5" Background="#dc3545" Foreground="White"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- Manage Decos -->
            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Manage Decos" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ Add New" Click="AddDeco_Click" Padding="15,8" Background="#28a745" Foreground="White"/>
                    </Grid>
                    
                    <DataGrid x:Name="DecosGrid" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Height="200"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Date Added" Binding="{Binding DateAdded, StringFormat='{}{0:MM/dd/yyyy}'}" Width="120"/>
                            <DataGridTemplateColumn Header="Actions" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Delete" Click="DeleteDeco_Click" Tag="{Binding Id}" Padding="10,5" Background="#dc3545" Foreground="White"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- Application Info -->
            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Application Information" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="The Toy Room Desktop" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Version 1.0.0" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                        A Windows desktop application for managing your collectible toy collection.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap">
                        Built with WPF and .NET 8, featuring SQLite database and Excel import/export capabilities.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
