<Window x:Class="TheToyRoomDesktop.Views.ViewItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Item" 
        Height="600" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/thetoyroom.ico"
        Background="#f8f9fa">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Item Details" FontSize="24" FontWeight="Bold" Foreground="#6f42c1" Margin="0,0,0,20"/>
            
            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <!-- Name -->
                    <TextBlock Text="Name" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="NameText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Character -->
                    <TextBlock Text="Character" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="CharacterText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Manufacturer -->
                    <TextBlock Text="Manufacturer" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ManufacturerText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Deco -->
                    <TextBlock Text="Deco" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DecoText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Classification -->
                    <TextBlock Text="Classification" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ClassificationText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Flags -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Reissue" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                            <TextBlock x:Name="ReissueText" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Stylized" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                            <TextBlock x:Name="StylizedText" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Prices -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Original Price" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                            <TextBlock x:Name="OriginalPriceText" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Current Value" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                            <TextBlock x:Name="CurrentValueText" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Gain/Loss -->
                    <TextBlock Text="Gain/Loss" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="GainLossText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Date Acquired -->
                    <TextBlock Text="Date Acquired" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DateAcquiredText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Date Added -->
                    <TextBlock Text="Date Added" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DateAddedText" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Image -->
                    <TextBlock Text="Image" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <Border x:Name="ImageBorder" 
                            Background="White" 
                            BorderBrush="#dee2e6" 
                            BorderThickness="1" 
                            CornerRadius="4" 
                            Padding="10" 
                            Margin="0,5,0,15"
                            Visibility="Collapsed">
                        <Image x:Name="ItemImage" MaxHeight="200" Stretch="Uniform"/>
                    </Border>
                    
                    <!-- Notes -->
                    <TextBlock Text="Notes" FontWeight="Bold" FontSize="12" Foreground="#6c757d" Margin="0,0,0,5"/>
                    <TextBlock x:Name="NotesText" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    
                    <!-- Close Button -->
                    <Button Content="Close" Click="Close_Click" Padding="30,10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
