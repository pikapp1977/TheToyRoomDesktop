<Page x:Class="TheToyRoomDesktop.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard"
      Background="#f8f9fa">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold" Foreground="#6f42c1" Margin="0,0,0,20"/>
            
            <!-- Statistics Cards -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Total Items Card -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0" 
                        BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Items" FontSize="14" Foreground="#6c757d"/>
                        <TextBlock x:Name="TotalItemsText" Text="0" FontSize="32" FontWeight="Bold" Foreground="#6f42c1" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Total Original Value Card -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="5,0,5,0" 
                        BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Original Value" FontSize="14" Foreground="#6c757d"/>
                        <TextBlock x:Name="TotalOriginalText" Text="$0.00" FontSize="32" FontWeight="Bold" Foreground="#28a745" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Total Current Value Card -->
                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" Margin="5,0,5,0" 
                        BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Current Value" FontSize="14" Foreground="#6c757d"/>
                        <TextBlock x:Name="TotalCurrentText" Text="$0.00" FontSize="32" FontWeight="Bold" Foreground="#007bff" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Gain/Loss Card -->
                <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0" 
                        BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Gain/Loss" FontSize="14" Foreground="#6c757d"/>
                        <TextBlock x:Name="GainLossText" Text="$0.00" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Recent Items -->
            <TextBlock Text="Recent Items" FontSize="24" FontWeight="Bold" Margin="0,30,0,10"/>
            <DataGrid x:Name="RecentItemsGrid" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      Background="White"
                      BorderBrush="#dee2e6"
                      BorderThickness="1"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="#f8f9fa"
                      CanUserResizeRows="False"
                      CanUserReorderColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Character" Binding="{Binding Character}" Width="*"/>
                    <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="*"/>
                    <DataGridTextColumn Header="Original Price" Binding="{Binding OriginalPrice, StringFormat=C2}" Width="120"/>
                    <DataGridTextColumn Header="Current Value" Binding="{Binding CurrentValue, StringFormat=C2}" Width="120"/>
                    <DataGridTextColumn Header="Date Added" Binding="{Binding DateAdded, StringFormat=MM/dd/yyyy}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
