<Window x:Class="TheToyRoomDesktop.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Height="200"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="../thetoyroom.ico"
        Background="#f8f9fa">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="PromptText" 
                   Grid.Row="0" 
                   Text="Enter value:" 
                   FontSize="14" 
                   Margin="0,0,0,10"/>
        
        <TextBox x:Name="ResponseTextBox" 
                 Grid.Row="1" 
                 Padding="8" 
                 FontSize="14"
                 KeyDown="ResponseTextBox_KeyDown"/>
        
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="OK" 
                    Click="OK_Click" 
                    IsDefault="True"
                    Padding="20,8" 
                    Margin="0,0,10,0"/>
            <Button Content="Cancel" 
                    Click="Cancel_Click" 
                    IsCancel="True"
                    Padding="20,8" 
                    Background="#6c757d"/>
        </StackPanel>
    </Grid>
</Window>
